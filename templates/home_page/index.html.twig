{% extends 'base.html.twig' %}

{% block title %}Accueil - AquaBiome
{% endblock %}
{% block page_name %}Accueil
{% endblock %}
{% block page_icon %}
	<i class="bi bi-house-door-fill"></i>
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<link rel="stylesheet" href="{{ asset('styles/home.css') }}">
	<style>
		.chart-card {
			background: white;
			padding: 20px;
			border-radius: 15px;
			box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
			margin-bottom: 25px;
		}
		.chart-card h3 {
			margin-top: 0;
			color: #333;
			font-size: 1.1rem;
			border-bottom: 2px solid #f0f0f0;
			padding-bottom: 10px;
			margin-bottom: 15px;
		}
		/* Assure que le SVG est centré et réactif */
		svg {
			display: block;
			margin: 0 auto;
			max-width: 100%;
		}
		/* Style pour les messages d'erreur flash */
		.alert-flash {
			background-color: #ff7675;
			color: white;
			padding: 15px;
			border-radius: 10px;
			margin-bottom: 20px;
			font-weight: bold;
			border-left: 5px solid #d63031;
			box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
		}
	</style>
{% endblock %}

{% block body %}
	<div
		class="home-content">

		{# --- AFFICHAGE DES ERREURS (Flash Messages) --- #}
		{% for message in app.flashes('error') %}
			<div class="alert-flash">
				<i class="bi bi-exclamation-triangle-fill"></i>
				{{ message }}
			</div>
		{% endfor %}

		{# Header de bienvenue #}
		<section class="user-welcome">
			<div class="welcome-avatar">
				{% if app.user and app.user.avatar %}
					<img src="{{ asset('uploads/avatars/' ~ app.user.avatar) }}" alt="Avatar" style="width: 80px; height: 80px; object-fit: cover; border-radius: 50%;">
				{% else %}
					<i class="bi bi-person-circle" style="font-size: 4rem; color: #ccc;"></i>
				{% endif %}
			</div>
			<p>
				Bienvenue sur votre tableau de bord,
				<strong>{{ app.user.nom|default(app.user.email|split('@')[0]) }}</strong>
			</p>
		</section>

		{# Section Alertes et Date de mise à jour #}
		<section
			class="alerts-section">

			{# -- TÂCHES À FAIRE (Rappels) -- #}
			{% if taches is defined and taches is not empty %}
				<div class="mb-4">
					{% for tache in taches %}
						<div class="alert alert-info alert-dismissible fade show" role="alert" style="border-left: 5px solid #0984e3;">
							<div class="d-flex justify-content-between align-items-center">
								<div>
									<strong>
										<i class="bi bi-journal-text"></i>
										À faire :</strong>
									{{ tache.titre }}
									<br>
									<small>Pour le :
										{{ tache.deadline|date('d/m/Y') }}</small>
								</div>
								<a href="{{ path('app_tache_complete', {id: tache.id}) }}" class="btn btn-sm btn-light text-primary fw-bold">
									<i class="bi bi-check-circle-fill"></i>
									Fait
								</a>
							</div>
						</div>
					{% endfor %}
				</div>
			{% endif %}

			{# -- ALERTES BDD -- #}
		{% if alertes is defined and alertes is not empty %}
			<div class="mb-4" id="alertes-container">
				{% for alerte in alertes %}
					<div class="alert alert-danger alert-dismissible fade show" role="alert" id="alerte-{{ alerte.id }}">
						<strong>{{ alerte.nom }} :</strong>
						{{ alerte.messageAlerte }}
						<br>
						<small class="text-muted">Le {{ alerte.dateAlerte|date('d/m/Y à H:i') }}</small>
						<button type="button" class="btn-close" aria-label="Fermer"
							onclick="dismissAlerte({{ alerte.id }}, '{{ path('app_alerte_dismiss', {id: alerte.id}) }}')">
						</button>
					</div>
				{% endfor %}
			</div>
		{% endif %}

			<div class="alert-card">
				<h3>Dernière activité</h3>
				<div style="min-height: 40px;">
					{% if mesure is null %}
						<p style="font-size: 0.9rem; color: #666;">Aucune mesure enregistrée en base de données.</p>
					{% else %}
						<p style="font-size: 0.9rem; color: #27ae60;">
							Dernier relevé le :
							<strong>{{ mesure.dateSaisie|date('d/m/Y à H:i') }}</strong>
						</p>
					{% endif %}
				</div>
			</div>
		</section>

		{# Grille des paramètres (Chiffres clés) #}
		<section class="stats-grid">
			<div class="stat-card">
				<span class="status-badge">Normal</span>
				<div class="stat-icon" style="color: #ff7675;">°C</div>
				<span class="stat-label">Température</span>
				<div class="stat-value">
					{{ (mesure and mesure.temperature is not null) ? mesure.temperature : '--' }}°C
				</div>
				<span class="stat-range">Plage: 22-26°C</span>
			</div>

			<div class="stat-card">
				<span class="status-badge">Normal</span>
				<div class="stat-icon" style="color: #74b9ff;">
					<i class="bi bi-eyedropper"></i>
				</div>
				<span class="stat-label">pH</span>
				<div class="stat-value">
					{{ (mesure and mesure.ph is not null) ? mesure.ph : '--' }}
				</div>
				<span class="stat-range">Plage: 6.5-7.5</span>
			</div>

			<div class="stat-card full-width">
				<span class="status-badge">Normal</span>
				<div class="stat-icon" style="color: #00cec9;">
					<i class="bi bi-droplet-fill"></i>
				</div>
				<span class="stat-label">GH (Dureté totale)</span>
				<div class="stat-value">
					{{ (mesure and mesure.gh is not null) ? mesure.gh : '--' }}
					°dH
				</div>
				<span class="stat-range">Plage: 6-12 °dH</span>
			</div>
		</section>

		<div class="content-area" style="overflow-y: auto; padding-bottom: 100px;">

			<div class="stats-grid">
				<div
					class="stat-card full-width" style="background: white !important;">

					{# Barre d'onglets #}
					<div class="tabs-header" style="display: flex; gap: 10px; margin-bottom: 15px;">
						<button class="tab-btn active" onclick="openTab(event, 'tab-gh')">GH</button>
						<button class="tab-btn" onclick="openTab(event, 'tab-ph')">pH / KH</button>
						<button class="tab-btn" onclick="openTab(event, 'tab-toxic')">Toxines</button>
					</div>

					{# Contenu des graphiques Symfony UX #}
					<div id="tab-gh" class="tab-content active">
						{{ render_chart(chartGh) }}
					</div>

					<div id="tab-ph" class="tab-content">
						{{ render_chart(chartPhKh) }}
					</div>

					<div id="tab-toxic" class="tab-content">
						{{ render_chart(chartToxic) }}
					</div>

				</div>
			</div>
		</div>

		<script>
			function openTab(evt, tabName) {
				var i, tabcontent, tablinks;
				tabcontent = document.getElementsByClassName("tab-content");
				for (i = 0; i < tabcontent.length; i++) {
					tabcontent[i].style.display = "none";
					tabcontent[i].classList.remove("active");
				}
				tablinks = document.getElementsByClassName("tab-btn");
				for (i = 0; i < tablinks.length; i++) {
					tablinks[i].classList.remove("active");
				}
				document.getElementById(tabName).style.display = "block";
				document.getElementById(tabName).classList.add("active");
				evt.currentTarget.classList.add("active");
			}

			function dismissAlerte(id, url) {
				// Appel AJAX pour marquer l'alerte comme vue en BDD
				fetch(url, {
					method: 'POST',
					headers: { 'X-Requested-With': 'XMLHttpRequest' }
				}).catch(() => {}); // Silencieux si erreur réseau

				// Masque l'alerte immédiatement côté UI
				const el = document.getElementById('alerte-' + id);
				if (el) {
					el.style.transition = 'opacity 0.3s ease';
					el.style.opacity = '0';
					setTimeout(() => el.remove(), 300);
				}
			}
		</script>
	{% endblock %}
