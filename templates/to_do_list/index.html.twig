{% extends 'base.html.twig' %}

{% block title %}To-do List - AquaBiome{% endblock %}
{% block page_icon %}<i class="bi bi-journal-text"></i>{% endblock %}
{% block page_name %}Ma Liste{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/todolist.css') }}">
{% endblock %}

{% block body %}
<div class="content-area">
    <div class="todo-container">

        {# ---- Barre d'ajout (EN HAUT) ---- #}
        <div class="add-bar">
            <i class="bi bi-pencil-fill" style="color: #b2bec3; font-size: 0.95rem; flex-shrink: 0;"></i>
            <input type="text" id="inlineTaskInput" placeholder="Ajouter une tâche…" onkeypress="handleInlineKeyPress(event)">
            <button class="add-bar-btn" onclick="confirmInlineTask()" title="Ajouter">
                <i class="bi bi-plus-lg"></i>
            </button>
        </div>

        {# ---- Titre + compteur ---- #}
        <div class="todo-header">
            <h2 class="todo-title">Ma Liste</h2>
            <div class="todo-stats" id="task-counter">0 Tâche</div>
        </div>

        {# ---- Section À Faire ---- #}
        <div class="todo-section">
            <span class="section-label">
                <i class="bi bi-hourglass-split"></i> À Faire
            </span>
            <div id="list-todo" class="todo-list-wrapper">
                <div class="todo-item" onclick="toggleTask(this)">
                    <div class="custom-checkbox"></div>
                    <span class="todo-text">Nourrir les poissons</span>
                    <button class="delete-btn" onclick="deleteTask(event, this)" title="Supprimer">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
                <div class="todo-item" onclick="toggleTask(this)">
                    <div class="custom-checkbox"></div>
                    <span class="todo-text">Vérifier le pH de l'eau</span>
                    <button class="delete-btn" onclick="deleteTask(event, this)" title="Supprimer">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        </div>

        {# ---- Section Terminées ---- #}
        <div class="todo-section">
            <span class="section-label">
                <i class="bi bi-check2-all"></i> Terminées
            </span>
            <div id="list-done" class="todo-list-wrapper">
                <div class="todo-item done" onclick="toggleTask(this)">
                    <div class="custom-checkbox"></div>
                    <span class="todo-text">Changer les plantes</span>
                    <button class="delete-btn" onclick="deleteTask(event, this)" title="Supprimer">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        function updateCounter() {
            const count = document.querySelectorAll('.todo-item').length;
            const counter = document.getElementById('task-counter');
            counter.innerText = count + (count > 1 ? " Tâches" : " Tâche");
        }

        function toggleTask(element) {
            const todoList = document.getElementById('list-todo');
            const doneList = document.getElementById('list-done');

            element.style.transform = 'scale(0.96)';
            setTimeout(() => {
                if (element.classList.contains('done')) {
                    element.classList.remove('done');
                    todoList.appendChild(element);
                } else {
                    element.classList.add('done');
                    doneList.appendChild(element);
                }
                element.style.transform = '';
            }, 140);
        }

        function deleteTask(event, button) {
            event.stopPropagation();
            const item = button.closest('.todo-item');
            item.style.transition = 'opacity 0.25s ease, transform 0.25s ease';
            item.style.opacity = '0';
            item.style.transform = 'translateX(16px)';
            setTimeout(() => {
                item.remove();
                updateCounter();
            }, 260);
        }

        function buildTaskElement(text) {
            const newItem = document.createElement('div');
            newItem.className = 'todo-item';
            newItem.onclick = function() { toggleTask(this); };
            newItem.style.opacity = '0';
            newItem.style.transform = 'translateY(8px)';
            newItem.innerHTML = `
                <div class="custom-checkbox"></div>
                <span class="todo-text">${text}</span>
                <button class="delete-btn" onclick="deleteTask(event, this)" title="Supprimer">
                    <i class="bi bi-x-lg"></i>
                </button>
            `;
            return newItem;
        }

        function confirmInlineTask() {
            const input = document.getElementById('inlineTaskInput');
            const text = input.value.trim();
            if (!text) { input.focus(); return; }

            const todoList = document.getElementById('list-todo');
            const newItem = buildTaskElement(text);
            todoList.prepend(newItem);

            requestAnimationFrame(() => {
                newItem.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                newItem.style.opacity = '1';
                newItem.style.transform = 'translateY(0)';
            });

            input.value = '';
            input.focus();
            updateCounter();
        }

        function handleInlineKeyPress(event) {
            if (event.key === 'Enter') confirmInlineTask();
        }

        document.addEventListener('DOMContentLoaded', updateCounter);
    </script>
{% endblock %}